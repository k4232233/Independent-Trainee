<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">
<!--       xmlns:p="http://www.springframework.org/schema/p"-->
<!--       xmlns:c="http://www.springframework.org/schema/c">-->
<!--    常量注入-->
    <bean id = "student1" class="com.sbi.Student">
        <property name="name" value="小米"/>
    </bean>
<!--Bean注入-->
    <bean id="addr" class="com.sbi.Address">
        <property name="address" value="重庆"/>
    </bean>
<!--ref是一个引用-->
    <bean id="student2" class="com.sbi.Student">
        <property name="name" value="小明"/>
        <property name="address" ref="addr"/>
    </bean>
<!--数组注入-->
    <bean id="student3" class="com.sbi.Student">
        <property name="name" value="小明"/>
        <property name="address" ref="addr"/>
        <property name="books">
            <array>
                <value>西游记</value>
                <value>红楼梦</value>
                <value>水浒传</value>
            </array>
        </property>
        <!--List注入-->
        <property name="hobby">
            <list>
                <value>听歌</value>
                <value>看电影</value>
                <value>爬山</value>
            </list>
        </property>
        <!--Map注入-->
        <property name="card">
            <map>
                <entry key="中国邮政" value="456456456465456"/>
                <entry key="建设" value="1456682255511"/>
            </map>
        </property>
        <!--set注入-->
        <property name="games">
            <set>
                <value>LOL</value>
                <value>BOB</value>
                <value>COC</value>
            </set>
        </property>
        <!--Null注入-->
        <property name="wife"><null/></property>
        <!--Properties注入-->
        <property name="info">
            <props>
                <prop key="学号">20190604</prop>
                <prop key="性别">男</prop>
                <prop key="姓名">小明</prop>
            </props>
        </property>

    </bean>



<!--    User的P命名空间注入-->
    <!--P(属性: properties)命名空间 , 直接注入属性-->
<!--    <bean id="user" class="com.sbi.User" p:name="huiyi" p:age="18"/>-->

    <!--C(构造: Constructor)命名空间 , 使用构造器注入-->
<!--    <bean id="user" class="com.sbi.User" c:name="rookie" c:age="18"/>-->

</beans>
